{
  "productName": "塞壬音乐下载器",
  "version": "0.1.0",
  "identifier": "com.siren.music-download",
  "build": {
    "beforeBuildCommand": "bun run build",
    "beforeDevCommand": "bun run build && bun run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "塞壬音乐下载器",
        "width": 1120,
        "height": 800,
        "minWidth": 1120,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; connect-src 'self' ipc://localhost https://monster-siren.hypergryph.com; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
