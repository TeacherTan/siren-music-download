{
  "name": "siren-music-download",
  "version": "0.1.0",
  "packageManager": "bun@1.3.13",
  "type": "module",
  "description": "基于 [Rust](https://www.rust-lang.org/) + [Tauri 2](https://tauri.app/) 构建的跨平台无损音乐下载工具，支持从[塞壬唱片官网](https://monster-siren.hypergryph.com/)下载全部专辑及曲目。",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "format": "prettier --write \"**/*.{js,mjs,cjs,ts,svelte,md}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,ts,svelte,md}\"",
    "lint": "bun run lint:eslint && bun run lint:rustfmt",
    "lint:eslint": "eslint .",
    "lint:rustfmt": "cargo fmt --all --check",
    "check": "bun run format:check && bun run lint:eslint && bun run lint:rustfmt && bun run check:types && bun run check:svelte && bun run check:build && bun run check:cargo",
    "check:types": "tsc --noEmit",
    "check:svelte": "bunx svelte-check",
    "check:build": "vite build",
    "check:cargo": "cargo check --workspace"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@humanspeak/svelte-motion": "^0.2.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "idb-keyval": "^6.2.2",
    "overlayscrollbars": "^2.15.1",
    "overlayscrollbars-svelte": "^0.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/cli": "^2.9.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.3.1",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
